{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_API_URL",
      "value": "http://hermes-api:8000"
    },
    {
      "key": "NEXT_PUBLIC_LOGIN_URL",
      "value": "/login"
    },
    {
      "key": "NEXT_PUBLIC_DEMO_URL",
      "value": "/demo"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
