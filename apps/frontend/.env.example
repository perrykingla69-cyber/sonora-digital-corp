# HERMES Frontend — Environment Variables

# API Configuration
# DEV: http://localhost:8000 (FastAPI hermes-api local)
VITE_API_URL=http://localhost:8000

# PROD: https://sonoradigitalcorp.com/api
VITE_API_URL_PROD=https://sonoradigitalcorp.com/api

# OAuth (mantener por compatibilidad con CONRADO, desactivado en HERMES)
# HERMES usa JWT token-based auth (localStorage)
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# Optional: API timeout (ms)
VITE_API_TIMEOUT=30000

# Optional: Debug mode
VITE_DEBUG=false
