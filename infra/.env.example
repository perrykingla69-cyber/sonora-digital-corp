# ============================================
# CONFIGURACION DE ENTORNO — MYSTIC
# Copiar a .env y completar con valores reales
# ============================================

# Base de datos
POSTGRES_USER=mystic_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=mystic_db

# Redis
REDIS_PASSWORD=your_redis_password_here

# Seguridad
SECRET_KEY=generate_a_64_char_random_string_here_for_jwt_signing
CORS_ORIGINS=https://sonoradigitalcorp.com,https://www.sonoradigitalcorp.com

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather

# WhatsApp (API oficial — opcional)
WA_API_KEY=your_whatsapp_api_key

# N8N
N8N_USER=mystic
N8N_PASSWORD=your_n8n_password_here

# Entorno
ENVIRONMENT=production
DEBUG=false

# URLs publicas (frontend)
NEXT_PUBLIC_API_URL=https://sonoradigitalcorp.com/api
NEXT_PUBLIC_WHATSAPP_BRIDGE_URL=https://sonoradigitalcorp.com/whatsapp-bridge
NEXT_PUBLIC_TELEGRAM_BOT=MysticAIBot
